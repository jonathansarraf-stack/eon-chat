# Eon Chat — Environment Variables

# Server port (default: 3777)
EON_PORT=3777

# Data directory for SQLite database (default: ~/.eon-chat)
# EON_DATA_DIR=/path/to/data

# Working directory for Claude Code (default: $HOME)
# EON_CWD=/path/to/your/project

# Stripe (for subscription management — optional)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# App URL (for Expo web preview)
# EXPO_PUBLIC_API_URL=http://localhost:3777
